#include <iostream>
using namespace std;

int main() {
    int rows = 5; // Defining total number of rows

    cout << "--- Day 20: Numbers and Alphabets Pattern ---" << endl;

    for (int i = 1; i <= rows; i++) {
        
        // Logic: If row number is ODD, print numbers
        if (i % 2 != 0) {
            for (int j = 1; j <= i; j++) {
                cout << j;
            }
        } 
        
        // Logic: If row number is EVEN, print characters
        else {
            char ch = 'A'; // Start character from 'A'
            for (int j = 1; j <= i; j++) {
                cout << ch;
                ch++; // Increment character (A -> B -> C...)
            }
        }
        
        cout << endl; 
    }

    return 0;
}
