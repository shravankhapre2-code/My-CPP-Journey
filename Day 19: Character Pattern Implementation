#include <iostream>
using namespace std;

int main() {
    int n = 4; // Number of rows

    cout << "--- Day 19: Character Pattern ---" << endl;

    for (int i = 1; i <= n; i++) {
        char ch = 'A'; // Start with 'A' for every new row
        for (int j = 1; j <= i; j++) {
            cout << ch;
            ch++; // Move to the next character (B, C, D...)
        }
        cout << endl;
    }

    return 0;
}
